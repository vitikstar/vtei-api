{
    "openapi": "3.0.0",
    "info": {
        "title": "VTEI Student API",
        "description": "REST API для мобільного додатку студентів ВТЕІ",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API Server"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Вхід по email або заліковій книжці (cb_number)",
                "operationId": "99d66635c4992aeaa6aa44ff653d0563",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "login",
                                    "password"
                                ],
                                "properties": {
                                    "login": {
                                        "description": "Номер залікової книжки",
                                        "type": "string",
                                        "example": "272062025"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успішний вхід. Якщо needs_group_select=true — показати список groups для вибору, потім PUT /auth/select-group"
                    },
                    "422": {
                        "description": "Невірний логін або пароль"
                    }
                }
            }
        },
        "/auth/select-group": {
            "put": {
                "tags": [
                    "Auth"
                ],
                "summary": "Вибрати активну групу (якщо needs_group_select=true). Повертає новий токен з групою.",
                "operationId": "02af5384dc1b3249e19fd9bf603d857c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "cb_number"
                                ],
                                "properties": {
                                    "cb_number": {
                                        "type": "string",
                                        "example": "272062025"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Новий токен з групою"
                    },
                    "404": {
                        "description": "Групу не знайдено"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Вихід з системи",
                "operationId": "6abf3b64a4bc7838d56346f05a5153af",
                "responses": {
                    "200": {
                        "description": "Успішний вихід"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/auth/recovery": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Запит на відновлення паролю",
                "operationId": "01b52afd775ad4fb4cfc7f0795444ae9",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Email надіслано"
                    }
                }
            }
        },
        "/auth/reset-password": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Встановити новий пароль за токеном",
                "operationId": "b8d03d5b689dcb65d3771f62d4f90a24",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "access_token",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "access_token": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string",
                                        "minLength": 6
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Пароль змінено"
                    }
                }
            }
        },
        "/dashboard": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Головний дашборд студента",
                "operationId": "faae45987996934eda46ad27a6f61dea",
                "responses": {
                    "200": {
                        "description": "Статистика студента"
                    },
                    "401": {
                        "description": "Не авторизований"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/profile": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Повна інформація про поточного студента",
                "operationId": "c6a79007a56511faa6f48397a2d15867",
                "responses": {
                    "200": {
                        "description": "Дані студента"
                    },
                    "401": {
                        "description": "Не авторизований"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/profile/password": {
            "put": {
                "tags": [
                    "Profile"
                ],
                "summary": "Зміна паролю",
                "operationId": "99a7e90be682b77160a9d19ae53e2b8d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "current_password",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "current_password": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string",
                                        "minLength": 6
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Пароль змінено"
                    },
                    "422": {
                        "description": "Невірний поточний пароль"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/profile/avatar": {
            "post": {
                "tags": [
                    "Profile"
                ],
                "summary": "Завантажити аватар",
                "operationId": "f821c4c6e7a828ccc615ac2f50158e15",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "properties": {
                                    "avatar": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Аватар оновлено"
                    },
                    "422": {
                        "description": "Невалідний файл"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/schedule": {
            "get": {
                "tags": [
                    "Schedule"
                ],
                "summary": "Розклад занять",
                "description": "За замовчуванням повертає весь поточний навчальний рік. Керується параметрами period або date_from/date_to.",
                "operationId": "a578f36850481808f9301936693dc7d8",
                "parameters": [
                    {
                        "name": "period",
                        "in": "query",
                        "description": "Швидкий вибір: year (за замовч.), month, week, day",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "year",
                                "month",
                                "week",
                                "day"
                            ]
                        }
                    },
                    {
                        "name": "date",
                        "in": "query",
                        "description": "Опорна дата для period (Y-m-d). За замовч. — сьогодні",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "date_from",
                        "in": "query",
                        "description": "Початок довільного діапазону (Y-m-d)",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "date_to",
                        "in": "query",
                        "description": "Кінець довільного діапазону (Y-m-d)",
                        "schema": {
                            "type": "string",
                            "format": "date"
                        }
                    },
                    {
                        "name": "teacher_id",
                        "in": "query",
                        "description": "Фільтр по викладачу (ID з таблиці users)",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "auditorium_id",
                        "in": "query",
                        "description": "Фільтр по аудиторії",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "subject_id",
                        "in": "query",
                        "description": "Фільтр по дисципліні",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "lesson_type",
                        "in": "query",
                        "description": "Фільтр по типу заняття (lecturing_hours, practical_hours, ...)",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Розклад згрупований по днях"
                    },
                    "401": {
                        "description": "Не авторизований"
                    },
                    "404": {
                        "description": "Групу не знайдено"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        },
        "/schedule/lesson/{id}": {
            "get": {
                "tags": [
                    "Schedule"
                ],
                "summary": "Детальна інформація про заняття",
                "operationId": "4c65182564543c7dbb15a9be4e6bd17a",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Деталі заняття"
                    },
                    "404": {
                        "description": "Заняття не знайдено"
                    }
                },
                "security": [
                    {
                        "BearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "BearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Dashboard",
            "description": "Dashboard"
        },
        {
            "name": "Profile",
            "description": "Profile"
        },
        {
            "name": "Schedule",
            "description": "Schedule"
        }
    ]
}